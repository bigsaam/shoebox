# shoebox service secrets. Render with 1Password — never commit a real .env:
#   op inject -i .env.example -o .env
#
# Create the item first (vault Homelab, item shoebox) with three fields:
#   password        openssl rand -base64 24   ← the one you paste into chat
#   api-token       openssl rand -hex 32      ← the CLI's bearer token; never shared
#   session-secret  openssl rand -hex 32      ← signs cookies; rotating logs everyone out

SHOEBOX_PASSWORD=op://Homelab/shoebox/password
SHOEBOX_API_TOKEN=op://Homelab/shoebox/api-token
SHOEBOX_SESSION_SECRET=op://Homelab/shoebox/session-secret

# Pin a digest once the image is published; :latest is fine while watchtower manages it.
SHOEBOX_IMAGE=ghcr.io/bigsaam/shoebox:latest

# Where the upload API listens. `tailscale ip -4` on manz-utils, so that
# `shoebox put` works from any tailnet host without exposing the API on the LAN.
# Leave as 127.0.0.1 to allow publishing only from the VM itself.
SHOEBOX_BIND_ADDR=100.x.y.z

# Host-side published port. Defaults to 8080. On manz-utils :8080 is taken (birdnet)
# and :8083 is firewalled to one admin host, so shoebox uses 8087 there and the CLI
# points at http://manz-utils:8087. The container always listens on 8080.
SHOEBOX_HOST_PORT=8087

SHOEBOX_SESSION_TTL=30d
SHOEBOX_MAX_BUNDLE_SIZE=100mb

# SHOEBOX_COOKIE_DOMAIN is deliberately unusable with share-{id}.enzoiwith.us:
# the only domain broad enough to span bundles is .enzoiwith.us, which would also
# send the session cookie to mytube, tripwala, and everything else. shoebox refuses
# to start if you set it. One password prompt per bundle is the price of that safety.
