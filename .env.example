# shoebox — local / generic configuration.
# For the homelab deployment use deploy/homelab/.env.example instead (1Password refs).
#
# Generate the three secrets:
#   openssl rand -base64 24    # SHOEBOX_PASSWORD (this is what you paste into chat)
#   openssl rand -hex 32       # SHOEBOX_API_TOKEN
#   openssl rand -hex 32       # SHOEBOX_SESSION_SECRET

# The one password you share with viewers.
SHOEBOX_PASSWORD=change-me

# Bearer token the CLI uses to publish. Never share this.
SHOEBOX_API_TOKEN=change-me

# Signs session cookies. Rotating it logs everyone out.
SHOEBOX_SESSION_SECRET=change-me

SHOEBOX_PORT=8080
SHOEBOX_DATA_DIR=./data
SHOEBOX_SESSION_TTL=30d
SHOEBOX_MAX_BUNDLE_SIZE=100mb

# --- addressing ------------------------------------------------------------
# Unset  => path mode: http://host/<id>/ , all bundles share one origin.
#           Fine for local dev. Links use SHOEBOX_BASE_URL.
# Set    => subdomain mode: every bundle is its own browser origin, which is
#           what production wants. Must contain {id} exactly once.
#
# SHOEBOX_HOST_TEMPLATE=share-{id}.enzoiwith.us
# SHOEBOX_PUBLIC_SCHEME=https

SHOEBOX_BASE_URL=http://localhost:8080

# --- serving ---------------------------------------------------------------
# true  (default) shoebox serves bundle files itself. Good for local dev.
# false           Caddy serves them; shoebox only answers /_/authz and the API.
# SHOEBOX_SERVE_FILES=true

# --- cookies ---------------------------------------------------------------
# Unset (default): host-only cookies. In subdomain mode a session for one bundle
#   is not even transmitted to another — strongest isolation, but the password is
#   asked once per bundle.
# Set to e.g. .preview.example.com: one password prompt covers every bundle.
#   Only valid when the template puts {id} in its own leading label. shoebox refuses
#   to start with a `share-{id}.example.com` style template, because the only cookie
#   domain wide enough would also cover every other service on example.com.
# SHOEBOX_COOKIE_DOMAIN=.preview.example.com
